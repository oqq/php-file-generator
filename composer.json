{
  "name": "oqq/php-file-generator",
  "type": "library",
  "require": {
    "php": "~8.5",
    "azjezz/psl": "^4.2",
    "cuyz/valinor": "^2.3",
    "nette/php-generator": "^4.2",
    "nikic/php-parser": "^5.7"
  },
  "require-dev": {
    "doctrine/dbal": "^4.4.1",
    "doctrine/migrations": "^3.9.5",
    "phpunit/phpunit": "^12.5.4"
  },
  "config": {
    "sort-packages": true,
    "bump-after-update": "dev",
    "audit": {
      "block-insecure": true
    }
  },
  "autoload": {
    "psr-4": {
      "Oqq\\Project\\": "result/",
      "Oqq\\PhpFileGenerator\\": "src/"
    },
    "autoload-dev": {
      "psr-4": {
        "Oqq\\PhpFileGenerator\\test\\": "tests/unit"
      }
    }
  }
}
