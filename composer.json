{
  "name": "oqq/php-file-generator",
  "type": "library",
  "require": {
    "php": "~8.5",
    "cuyz/valinor": "^2.3",
    "nette/php-generator": "^4.2",
    "nikic/php-parser": "^5.7",
    "php-standard-library/php-standard-library": "^6.1"
  },
  "require-dev": {
    "doctrine/dbal": "^4.4.3",
    "doctrine/migrations": "^3.9.6",
    "phpunit/phpunit": "^13.1.5"
  },
  "config": {
    "sort-packages": true,
    "bump-after-update": "dev",
    "audit": {
      "block-insecure": true
    }
  },
  "autoload": {
    "psr-4": {
      "Oqq\\Project\\": "result/",
      "Oqq\\PhpFileGenerator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Oqq\\PhpFileGenerator\\test\\": "tests/unit"
    }
  }
}
